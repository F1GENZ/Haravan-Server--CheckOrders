    var popupClose = document.getElementById('f1g-popup-close');
    var phoneW = document.getElementById('f1g-phone-wrap');
    var codeW = document.getElementById('f1g-code-wrap');
    var emptyEl = document.getElementById('f1g-empty');
    var listEl = document.getElementById('f1g-order-list');
    var pagingEl = document.getElementById('f1g-paging');
    var activeTab = 'phone';
    var lookupMethod = 'phone_and_code';
    var displayMode = 'inline';
    var captchaToken = '';
    var captchaWidgetId = null;

    // All orders + pagination
    var allOrders = [];
    var perPage = 3;
    var curPage = 1;

    // ─── i18n ───
    var I18N = {
      vi: {
