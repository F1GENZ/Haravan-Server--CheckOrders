# Runtime
NODE_ENV=production
PORT=3333
BUILD_TIME=
SOURCE_VERSION=
TRUST_PROXY=1
REQUEST_BODY_LIMIT=1mb
WEBHOOK_BODY_LIMIT=256kb

# Public URLs
FRONTEND_URL=https://checkorders.f1genz.dev
API_BASE_URL=https://api-checkorders.f1genz.dev
WIDGET_API_URL=https://api-checkorders.f1genz.dev
WIDGET_PUBLIC_URL=https://checkorders.f1genz.dev
CORS_ALLOWED_ORIGINS=https://checkorders.f1genz.dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Durable storage (recommended for production)
# Redis is still used for runtime cache/session/rate-limit. Postgres keeps
# shop/settings/subscription/webhook/lookup audit data across deploys.
DATABASE_URL=postgresql://checkorders:change-me@localhost:5432/checkorders?schema=public

# 32-byte base64/hex/plain secret. Required when DATABASE_URL is enabled.
# Do not reuse HRV_CLIENT_SECRET.
DATA_ENCRYPTION_KEY=

# HMAC secret for lookup audit hashes. Do not leave empty in production.
LOOKUP_HASH_SECRET=

# Haravan OAuth
HRV_URL_AUTHORIZE=https://accounts.haravan.com/connect/authorize
HRV_URL_CONNECT_TOKEN=https://accounts.haravan.com/connect/token
HRV_RESPONSE_TYPE=code
HRV_RESPONSE_MODE=query
HRV_NONCE=checkorders_nonce

# App credentials
HRV_CLIENT_ID=
HRV_CLIENT_SECRET=

# Scopes
HRV_SCOPE_LOGIN=openid profile email org userinfo
HRV_SCOPE_INSTALL=openid profile address email phone org userinfo com.read_orders com.read_shop grant_service offline_access

# Callback URLs
HRV_LOGIN_CALLBACK_URL=https://checkorders.f1genz.dev/install/login
HRV_INSTALL_CALLBACK_URL=https://api-checkorders.f1genz.dev/api/oauth/install/grandservice
HRV_WEBHOOK_URL=https://api-checkorders.f1genz.dev/api/oauth/install/webhooks
HRV_WEBHOOK_SECRET=
HRV_WEBHOOK_AUTO_SUBSCRIBE=true

# Grant types
HRV_GRANT_TYPE_INSTALL=authorization_code
HRV_GRANT_TYPE_REFRESH=refresh_token

# Internal session
APP_SESSION_SECRET=
APP_SESSION_TTL=12h
APP_SESSION_TTL_SECONDS=43200

# Order lookup
ORDER_LOOKUP_QUOTA_PER_SHOP=500
ORDER_LOOKUP_LOOKBACK_DAYS=365
ORDER_LOOKUP_MAX_PAGES=20
ORDER_LOOKUP_FALLBACK_LOOKBACK_DAYS=3650
ORDER_LOOKUP_FALLBACK_MAX_PAGES=80
ORDER_LOOKUP_CACHE_SECONDS=180
ORDER_LOOKUP_NEGATIVE_CACHE_SECONDS=45
HARAVAN_ACCESS_TOKEN_MAX_EXPECTED_TTL_MS=

# Storefront protection
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Notifications
TELEGRAM_ALERT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_APP_NAME=F1GENZ CheckOrders
TELEGRAM_APP_ENV=production
TELEGRAM_ALERT_DEDUPE_SECONDS=300
TELEGRAM_NOTIFY_HTTP_4XX=false
